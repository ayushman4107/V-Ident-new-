{
  "expo": {
    "name": "V-Ident",
    "slug": "v-ident",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vident",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1224"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vident.app",
      "infoPlist": {
        "NSCameraUsageDescription": "V-Ident needs camera access for identity verification"
      }
    },
    "android": {
      "package": "com.vident.app",
      "adaptiveIcon": {
        "backgroundColor": "#0D1224",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "V-Ident needs camera access for identity verification"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
